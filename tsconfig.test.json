{
  "extends": "./tsconfig.json",
  "include": [
    "client/src/**/*",
    "client/tests/**/*",
    "shared/**/*",
    "packages/**/*"
  ],
  "exclude": ["node_modules", "build", "dist"],
  "compilerOptions": {
    "types": ["node", "vite/client", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./packages/shared-core/*"]
    }
  }
}
